<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC 
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

    <class name="BranchDTO" table="ST_BRANCH">
    
        <!-- Primary Key -->
        <id name="id" type="java.lang.Long">
            <column name="ID"></column>
            <generator class="increment"></generator>
        </id>

        <!-- Branch Fields -->
        <property name="branchCode" type="java.lang.String">
            <column name="BRANCH_CODE"/>
        </property>

        <property name="branchName" type="java.lang.String">
            <column name="BRANCH_NAME"/>
        </property>

        <property name="branchLocation" type="java.lang.String">
            <column name="BRANCH_LOCATION"/>
        </property>

        <property name="branchStatus" type="java.lang.String">
            <column name="BRANCH_STATUS"/>
        </property>

        <!-- BaseDTO Fields -->
        <property name="createdBy" type="java.lang.String" length="50">
            <column name="CREATED_BY"/>
        </property>

        <property name="modifiedBy" type="java.lang.String" length="50">
            <column name="MODIFIED_BY"/>
        </property>

        <property name="createdDatetime" type="java.sql.Timestamp">
            <column name="CREATED_DATETIME"/>
        </property>

        <property name="modifiedDatetime" type="java.sql.Timestamp">
            <column name="MODIFIED_DATETIME"/>
        </property>

    </class>

</hibernate-mapping>