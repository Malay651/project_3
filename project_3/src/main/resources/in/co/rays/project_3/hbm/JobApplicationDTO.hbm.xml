<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

    <class name="JobApplicationDTO" table="ST_JOB_APPLICATION">

        <!-- Primary Key -->
        <id name="id" type="java.lang.Long">
            <column name="ID"/>
            <generator class="increment"/>
        </id>

        <!-- Job Application Fields -->

        <property name="applicationName" type="java.lang.String">
            <column name="APPLICATION_NAME"/>
        </property>

        <property name="jobTitle" type="java.lang.String">
            <column name="JOB_TITLE"/>
        </property>

        <property name="resumeLink" type="java.lang.String">
            <column name="RESUME_LINK"/>
        </property>

        <property name="applicationDate" type="java.util.Date">
            <column name="APPLICATION_DATE"/>
        </property>

        <property name="interviewDate" type="java.util.Date">
            <column name="INTERVIEW_DATE"/>
        </property>

        <property name="applicationStatus" type="java.lang.String">
            <column name="APPLICATION_STATUS"/>
        </property>

        <!-- BaseDTO Fields -->

        <property name="createdBy" type="java.lang.String" length="50">
            <column name="CREATED_BY"/>
        </property>

        <property name="modifiedBy" type="java.lang.String" length="50">
            <column name="MODIFIED_BY"/>
        </property>

        <property name="createdDatetime" type="java.sql.Timestamp">
            <column name="CREATED_DATETIME"/>
        </property>

        <property name="modifiedDatetime" type="java.sql.Timestamp">
            <column name="MODIFIED_DATETIME"/>
        </property>

    </class>

</hibernate-mapping>